---
import { resume } from '../../profile/resume';
---
<ol class="space-y-12 border-l border-zinc-200 pl-6 dark:border-zinc-800">
  {resume.experience.map((entry) => (
    <li class="relative">
      <span class="absolute -left-[31px] top-2 h-2.5 w-2.5 rounded-full bg-accent ring-4 ring-zinc-50 dark:ring-zinc-950" aria-hidden="true"></span>
      <div class="flex items-start justify-between gap-x-4">
        <h3 class="min-w-0 font-display text-xl font-semibold leading-snug text-zinc-900 dark:text-zinc-50">
          {entry.role} <span class="text-zinc-500 dark:text-zinc-400">· {entry.org}</span>
        </h3>
        <time class="shrink-0 pt-0.5 text-sm text-zinc-500 dark:text-zinc-400">{entry.period}</time>
      </div>
      <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">{entry.location}</p>
      <ul class="mt-3 list-disc space-y-1.5 pl-5 text-zinc-700 marker:text-accent dark:text-zinc-300">
        {entry.bullets.map((b) => <li>{b}</li>)}
      </ul>
    </li>
  ))}
</ol>

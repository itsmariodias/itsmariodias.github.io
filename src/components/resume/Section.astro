---
interface Props {
  id?: string;
  eyebrow: string;
  title: string;
}
const { id, eyebrow, title } = Astro.props;
---
<section id={id} class="container-narrow py-16">
  <p class="mb-2 text-xs font-medium uppercase tracking-[0.18em] text-accent">{eyebrow}</p>
  <h2 class="font-display text-3xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50 sm:text-4xl">
    {title}
  </h2>
  <div class="mt-8">
    <slot />
  </div>
</section>

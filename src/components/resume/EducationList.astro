---
import { resume } from '../../profile/resume';
---
<ul class="divide-y divide-zinc-200 dark:divide-zinc-800">
  {resume.education.map((entry) => (
    <li class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1 py-5">
      <div>
        <h3 class="font-display text-lg font-semibold text-zinc-900 dark:text-zinc-50">{entry.qualification}</h3>
        <p class="text-sm text-zinc-600 dark:text-zinc-400">{entry.institution}</p>
        {entry.affiliation && (
          <p class="text-xs text-zinc-500 dark:text-zinc-500">{entry.affiliation}</p>
        )}
      </div>
      <div class="text-right text-sm text-zinc-500 dark:text-zinc-400">
        <p>{entry.period}</p>
        {entry.result && <p class="font-medium text-zinc-700 dark:text-zinc-300">{entry.result}</p>}
      </div>
    </li>
  ))}
</ul>

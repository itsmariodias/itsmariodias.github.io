---
import { resume } from '../../profile/resume';
---
<ul class="grid gap-4 sm:grid-cols-2">
  {resume.certifications.map((c) => {
    const Inner = c.url ? 'a' : 'div';
    const linkProps = c.url
      ? { href: c.url, target: '_blank', rel: 'noopener noreferrer' }
      : {};
    return (
      <li class="contents">
        <Inner
          {...linkProps}
          class="group block h-full rounded-xl border border-zinc-200 bg-white p-5 transition hover:border-accent dark:border-zinc-800 dark:bg-zinc-900/40 dark:hover:border-accent"
        >
          <div class="flex items-baseline justify-between gap-3">
            <h3 class="font-display text-base font-semibold text-zinc-900 dark:text-zinc-50">{c.title}</h3>
            <span class="shrink-0 text-xs text-zinc-500 dark:text-zinc-400">{c.year}</span>
          </div>
          <p class="mt-1 flex items-center gap-1.5 text-sm text-zinc-500 dark:text-zinc-400">
            {c.issuer}
            {c.url && (
              <svg
                class="h-3.5 w-3.5 opacity-0 transition group-hover:opacity-100"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M7 7h10v10" />
                <path d="M7 17 17 7" />
              </svg>
            )}
          </p>
        </Inner>
      </li>
    );
  })}
</ul>

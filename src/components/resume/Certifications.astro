---
import { resume } from '../../data/resume';
---
<ul class="grid gap-4 sm:grid-cols-2">
  {resume.certifications.map((c) => (
    <li class="rounded-xl border border-zinc-200 bg-white p-5 transition hover:border-accent dark:border-zinc-800 dark:bg-zinc-900/40 dark:hover:border-accent">
      <div class="flex items-baseline justify-between gap-3">
        <h3 class="font-display text-base font-semibold text-zinc-900 dark:text-zinc-50">{c.title}</h3>
        <span class="shrink-0 text-xs text-zinc-500 dark:text-zinc-400">{c.year}</span>
      </div>
      <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">{c.issuer}</p>
    </li>
  ))}
</ul>

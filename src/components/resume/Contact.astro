---
import { resume } from '../../profile/resume';

const iconClass = 'h-5 w-5 shrink-0 text-zinc-500 transition group-hover:text-accent dark:text-zinc-400';
---
<div class="grid gap-3 sm:grid-cols-2">
  <a href={`mailto:${resume.email}`} class="group flex items-center gap-4 rounded-xl border border-zinc-200 px-5 py-4 transition hover:border-accent dark:border-zinc-800 dark:hover:border-accent">
    <svg class={iconClass} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="5" width="18" height="14" rx="2" />
      <path d="m3 7 9 6 9-6" />
    </svg>
    <div>
      <p class="text-xs uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Email</p>
      <p class="mt-0.5 font-medium text-zinc-900 dark:text-zinc-50">{resume.email}</p>
    </div>
  </a>

  {resume.socials.map((s) => (
    <a href={s.url} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 rounded-xl border border-zinc-200 px-5 py-4 transition hover:border-accent dark:border-zinc-800 dark:hover:border-accent">
      {s.label === 'GitHub' && (
        <svg class={iconClass} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.09-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.18.92-.26 1.9-.39 2.88-.39.98 0 1.96.13 2.88.39 2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.77.11 3.06.74.8 1.19 1.83 1.19 3.09 0 4.42-2.7 5.4-5.27 5.68.41.36.78 1.07.78 2.16 0 1.56-.01 2.81-.01 3.19 0 .31.21.68.8.56C20.21 21.38 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
        </svg>
      )}
      {s.label === 'LinkedIn' && (
        <svg class={iconClass} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
        </svg>
      )}
      <div>
        <p class="text-xs uppercase tracking-wider text-zinc-500 dark:text-zinc-400">{s.label}</p>
        <p class="mt-0.5 font-medium text-zinc-900 dark:text-zinc-50">{s.handle ?? s.url}</p>
      </div>
    </a>
  ))}
</div>

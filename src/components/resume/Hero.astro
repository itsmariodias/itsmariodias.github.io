---
import { Image } from 'astro:assets';
import { resume } from '../../profile/resume';
import TerminalHeading from '../TerminalHeading.astro';
import profile from '../../assets/profile.png';
---
<section class="container-narrow pt-20 pb-12">
  <Image
    src={profile}
    alt="Mario Dias"
    width={128}
    class="mb-5 h-16 w-16 rounded-full object-cover ring-1 ring-zinc-200 dark:ring-zinc-800"
  />
  <p class="mb-3 text-xs font-medium uppercase tracking-[0.18em] text-accent">{resume.tagline}</p>
  <TerminalHeading text={`Hi, I'm ${resume.name}.`} />
  <p class="mt-6 max-w-2xl text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">
    {resume.about[0]}
  </p>
  <p class="mt-4 max-w-2xl text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">
    {resume.about[1]}
  </p>
  <p class="mt-8 text-sm text-zinc-500 dark:text-zinc-400">{resume.location}</p>
</section>

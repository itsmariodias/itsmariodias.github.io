---
import { resume } from '../../data/resume';
---
<section class="container-narrow pt-20 pb-12">
  <p class="mb-3 text-xs font-medium uppercase tracking-[0.18em] text-accent">{resume.tagline}</p>
  <h1 class="font-display text-5xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50 sm:text-6xl">
    {resume.name}
  </h1>
  <p class="mt-6 max-w-2xl text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">
    {resume.about[0]}
  </p>
  <p class="mt-4 max-w-2xl text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">
    {resume.about[1]}
  </p>
  <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-zinc-500 dark:text-zinc-400">
    <span>{resume.location}</span>
    <span class="hidden h-1 w-1 rounded-full bg-zinc-400 sm:block" aria-hidden="true"></span>
    <a href={`mailto:${resume.email}`} class="transition hover:text-accent">{resume.email}</a>
  </div>
</section>

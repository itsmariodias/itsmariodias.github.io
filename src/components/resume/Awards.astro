---
import { resume } from '../../profile/resume';
---
<ul class="space-y-4">
  {resume.awards.map((a) => (
    <li class="flex items-start justify-between gap-x-4 border-l-2 border-accent pl-4">
      <div class="min-w-0">
        <h3 class="font-display text-lg font-semibold leading-snug text-zinc-900 dark:text-zinc-50">{a.title}</h3>
        <p class="mt-0.5 text-sm text-zinc-600 dark:text-zinc-400">{a.issuer}</p>
        {a.note && <p class="mt-1 text-sm italic text-zinc-500 dark:text-zinc-400">{a.note}</p>}
      </div>
      <span class="shrink-0 pt-0.5 text-sm text-zinc-500 dark:text-zinc-400">{a.year}</span>
    </li>
  ))}
</ul>

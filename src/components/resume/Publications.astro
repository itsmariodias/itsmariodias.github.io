---
import { resume } from '../../data/resume';
---
<ol class="space-y-6">
  {resume.publications.map((p) => (
    <li class="rounded-2xl border border-zinc-200 p-6 transition hover:border-accent dark:border-zinc-800 dark:hover:border-accent">
      <h3 class="font-display text-lg font-semibold leading-snug text-zinc-900 dark:text-zinc-50">
        {p.doi ? (
          <a href={p.doi} target="_blank" rel="noopener noreferrer" class="hover:text-accent">
            {p.title}
          </a>
        ) : (
          p.title
        )}
      </h3>
      <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">{p.authors}</p>
      <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-500">
        <span class="italic">{p.venue}</span>, {p.year}
      </p>
      {p.doi && (
        <p class="mt-3 text-xs">
          <a href={p.doi} target="_blank" rel="noopener noreferrer" class="font-mono text-accent hover:underline">
            {p.doi.replace('https://', '')}
          </a>
        </p>
      )}
    </li>
  ))}
</ol>

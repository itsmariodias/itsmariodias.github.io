---
import { resume } from '../../data/resume';
const groups = Object.entries(resume.skills);
---
<dl class="space-y-6">
  {groups.map(([group, items]) => (
    <div class="grid gap-3 sm:grid-cols-[160px_1fr]">
      <dt class="text-sm font-medium uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
        {group}
      </dt>
      <dd>
        <ul class="flex flex-wrap gap-2">
          {items.map((s) => (
            <li class="rounded-full border border-zinc-200 px-3.5 py-1.5 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-300">
              {s}
            </li>
          ))}
        </ul>
      </dd>
    </div>
  ))}
</dl>

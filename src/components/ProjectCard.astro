---
import ClampToggle from './ClampToggle.astro';

interface ProjectLink {
  label: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  year?: string;
  tags?: string[];
  links: ProjectLink[];
  cover?: string;
}

const { title, description, year, tags, links, cover } = Astro.props;

const iconFor = (label: string) => {
  switch (label) {
    case 'GitHub':
      return 'github';
    case 'Demo':
    case 'Website':
      return 'external';
    case 'Article':
      return 'article';
    case 'Paper':
      return 'paper';
    default:
      return 'external';
  }
};
---
<article class="overflow-hidden rounded-2xl border border-zinc-200 transition hover:border-accent dark:border-zinc-800 dark:hover:border-accent">
  <div class={cover ? 'flex flex-col gap-6 p-6 sm:flex-row' : 'p-6'}>
    {cover && (
      <img
        src={cover}
        alt=""
        loading="lazy"
        class="aspect-video w-full shrink-0 rounded-lg object-cover sm:aspect-square sm:h-32 sm:w-32"
      />
    )}
    <div class="min-w-0 flex-1">
      <div class="flex items-start justify-between gap-x-4">
        <h3 class="min-w-0 font-display text-xl font-semibold leading-snug text-zinc-900 dark:text-zinc-50">{title}</h3>
        {year && <span class="shrink-0 pt-0.5 text-sm text-zinc-500 dark:text-zinc-400">{year}</span>}
      </div>

      <ClampToggle text={description} class="mt-3" />

      {tags && tags.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-2">
          {tags.map((t) => (
            <li class="rounded-full border border-zinc-200 px-2.5 py-0.5 text-xs text-zinc-600 dark:border-zinc-800 dark:text-zinc-400">
              {t}
            </li>
          ))}
        </ul>
      )}

      {links.length > 0 && (
        <ul class="mt-5 flex flex-wrap gap-2">
          {links.map((l) => {
            const icon = iconFor(l.label);
            return (
              <li>
                <a
                  href={l.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group inline-flex items-center gap-1.5 rounded-full border border-zinc-200 px-3.5 py-1.5 text-xs font-medium text-zinc-700 transition hover:border-accent hover:text-accent dark:border-zinc-800 dark:text-zinc-300 dark:hover:border-accent dark:hover:text-accent"
                >
                  {icon === 'github' && (
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.09-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.18.92-.26 1.9-.39 2.88-.39.98 0 1.96.13 2.88.39 2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.77.11 3.06.74.8 1.19 1.83 1.19 3.09 0 4.42-2.7 5.4-5.27 5.68.41.36.78 1.07.78 2.16 0 1.56-.01 2.81-.01 3.19 0 .31.21.68.8.56C20.21 21.38 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
                    </svg>
                  )}
                  {icon === 'article' && (
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M4 4h12a2 2 0 0 1 2 2v14l-4-2-4 2-4-2-2 1V4z" />
                      <path d="M8 8h6M8 12h6M8 16h4" />
                    </svg>
                  )}
                  {icon === 'paper' && (
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                      <path d="M14 2v6h6M16 13H8M16 17H8M10 9H8" />
                    </svg>
                  )}
                  {icon === 'external' && (
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M15 3h6v6" />
                      <path d="M10 14 21 3" />
                      <path d="M19 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h6" />
                    </svg>
                  )}
                  {l.label}
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </div>
</article>

---
---
<button
  type="button"
  id="theme-toggle"
  aria-label="Toggle theme"
  class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-zinc-300 text-zinc-700 transition hover:border-accent hover:text-accent sm:h-9 sm:w-9 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-accent dark:hover:text-accent"
>
  <svg class="hidden h-4 w-4 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>
  <svg class="h-4 w-4 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z" />
  </svg>
</button>

<script is:inline>
  (() => {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const root = document.documentElement;
      // Suppress transitions for the swap so nothing animates from the old
      // theme to the new one (otherwise e.g. the copy button looks "stuck").
      root.classList.add('theme-switching');
      const isDark = root.classList.toggle('dark');
      try {
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      } catch {}
      requestAnimationFrame(() =>
        requestAnimationFrame(() => root.classList.remove('theme-switching')),
      );
    });
  })();
</script>

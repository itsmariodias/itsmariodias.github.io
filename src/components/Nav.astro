---
import ThemeToggle from './ThemeToggle.astro';
const path = Astro.url.pathname;
const isBlog = path.startsWith('/blog') || path.startsWith('/tags');
const isResume = !isBlog;

const linkClass = (active: boolean) =>
  `relative text-sm font-medium tracking-wide transition ${
    active
      ? 'text-zinc-900 dark:text-zinc-50'
      : 'text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-50'
  }`;
---
<header class="sticky top-0 z-40 border-b border-zinc-200/60 bg-zinc-50/80 backdrop-blur dark:border-zinc-800/60 dark:bg-zinc-950/80">
  <div class="container-wide flex h-16 items-center justify-between">
    <a href="/" class="font-display text-lg font-semibold tracking-tight text-zinc-900 dark:text-zinc-50">
      Mario&nbsp;Dias
    </a>
    <nav class="flex items-center gap-8">
      <a href="/" class={linkClass(isResume)}>
        Resume
        {isResume && <span class="absolute -bottom-[21px] left-0 right-0 h-px bg-accent" />}
      </a>
      <a href="/blog" class={linkClass(isBlog)}>
        Blog
        {isBlog && <span class="absolute -bottom-[21px] left-0 right-0 h-px bg-accent" />}
      </a>
      <ThemeToggle />
    </nav>
  </div>
</header>

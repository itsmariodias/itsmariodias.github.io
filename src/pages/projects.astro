---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Publications from '../components/resume/Publications.astro';
import { projects, publications } from '../profile/projects';

const sortedProjects = [...projects].sort((a, b) => (b.year ?? '').localeCompare(a.year ?? ''));

const sections = [
  { id: 'projects', label: 'Projects', count: projects.length },
  { id: 'publications', label: 'Publications', count: publications.length },
];
---
<BaseLayout title="Projects · Mario Dias" description="A curated list of personal projects and research publications.">
  <div class="relative">
    <aside class="pointer-events-none absolute left-1/2 top-0 ml-[26rem] hidden h-full w-44 xl:block">
      <div class="pointer-events-auto sticky top-24">
        <p class="mb-3 text-xs font-medium uppercase tracking-[0.18em] text-zinc-500 dark:text-zinc-400">
          On this page
        </p>
        <ol class="space-y-1 border-l border-zinc-200 dark:border-zinc-800">
          {sections.map((s) => (
            <li>
              <a
                href={`#${s.id}`}
                data-section-link={s.id}
                class="group flex items-baseline justify-between gap-3 py-1.5 pl-4 text-sm text-zinc-600 transition hover:text-accent dark:text-zinc-400"
              >
                <span class="font-medium">{s.label}</span>
                <span class="text-xs text-zinc-400 dark:text-zinc-500">{s.count}</span>
              </a>
            </li>
          ))}
        </ol>
      </div>
    </aside>

    <section id="projects" class="container-narrow scroll-mt-24 py-16">
      <p class="mb-2 text-xs font-medium uppercase tracking-[0.18em] text-accent">Work</p>
      <h1 class="font-display text-4xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50 sm:text-5xl">
        Projects
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-zinc-600 dark:text-zinc-400">
        A curated list of personal projects and research publications. Most have a GitHub repo or paper attached.
      </p>

      {projects.length === 0 ? (
        <p class="mt-12 text-zinc-600 dark:text-zinc-400">Nothing here yet.</p>
      ) : (
        <ul class="mt-12 space-y-6">
          {sortedProjects.map((p) => (
            <li>
              <ProjectCard
                title={p.title}
                description={p.description}
                year={p.year}
                tags={p.tags}
                links={p.links}
                cover={p.cover}
              />
            </li>
          ))}
        </ul>
      )}
    </section>

    <section id="publications" class="container-narrow scroll-mt-24 pb-16">
      <p class="mb-2 text-xs font-medium uppercase tracking-[0.18em] text-accent">Research</p>
      <h2 class="font-display text-3xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50 sm:text-4xl">
        Publications
      </h2>
      <div class="mt-8">
        <Publications />
      </div>
    </section>
  </div>

  <script>
    import { initScrollSpy } from '../utils/scrollspy';
    initScrollSpy({
      linkSelector: 'a[data-section-link]',
      activeClasses: ['text-accent', 'font-medium'],
      inactiveClasses: ['text-zinc-600', 'dark:text-zinc-400'],
    });
  </script>
</BaseLayout>

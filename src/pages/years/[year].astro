---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../utils/formatDate';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const years = new Set<number>();
  for (const post of posts) years.add(post.data.pubDate.getFullYear());
  return [...years].map((year) => ({
    params: { year: String(year) },
    props: {
      year,
      posts: posts
        .filter((p) => p.data.pubDate.getFullYear() === year)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

interface Props {
  year: number;
  posts: CollectionEntry<'blog'>[];
}

const { year, posts } = Astro.props;
---
<BaseLayout title={`${year} · Mario Dias`}>
  <section class="container-narrow py-16">
    <p class="mb-2 text-xs font-medium uppercase tracking-[0.18em] text-accent">Year</p>
    <h1 class="font-display text-4xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50 sm:text-5xl">
      {year}
    </h1>
    <p class="mt-3 text-zinc-600 dark:text-zinc-400">
      {posts.length} post{posts.length === 1 ? '' : 's'}
    </p>

    <ul class="mt-10 divide-y divide-zinc-200 dark:divide-zinc-800">
      {posts.map((post) => (
        <li class="py-5">
          <a href={`/blog/${post.slug}/`} class="group flex items-baseline justify-between gap-x-4">
            <h2 class="min-w-0 font-display text-xl font-semibold text-zinc-900 transition group-hover:text-accent dark:text-zinc-50">
              {post.data.title}
            </h2>
            <time class="shrink-0 text-sm text-zinc-500 dark:text-zinc-400">{formatDate(post.data.pubDate)}</time>
          </a>
        </li>
      ))}
    </ul>

    <p class="mt-12 text-sm">
      <a href="/years/" class="text-accent hover:underline">← All years</a>
    </p>
  </section>
</BaseLayout>

---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CopyCode from '../../components/CopyCode.astro';
import { formatDate } from '../../utils/formatDate';
import { readingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );
  return posts.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      post,
      newer: i > 0 ? posts[i - 1] : null,
      older: i < posts.length - 1 ? posts[i + 1] : null,
    },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
  newer: CollectionEntry<'blog'> | null;
  older: CollectionEntry<'blog'> | null;
}

const { post, newer, older } = Astro.props;
const { Content } = await post.render();
const reading = readingTime(post.body);
---
<BaseLayout title={`${post.data.title} · Mario Dias`} description={post.data.description} canonicalUrl={post.data.canonicalUrl} ogImage={`/og/${post.slug}.png`}>
  <article class="container-narrow py-16">
    <header class="mb-10">
      <p class="mb-2 text-xs font-medium uppercase tracking-[0.18em] text-accent">Post</p>
      <h1 class="font-display text-4xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50 sm:text-5xl">
        {post.data.title}
      </h1>
      {post.data.description && (
        <p class="mt-4 text-lg leading-relaxed text-zinc-500 dark:text-zinc-400 sm:text-xl">{post.data.description}</p>
      )}
      <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-zinc-500 dark:text-zinc-400">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        <span aria-hidden="true">·</span>
        <span>{reading}</span>
        {post.data.updatedDate && (
          <>
            <span aria-hidden="true">·</span>
            <span>Updated {formatDate(post.data.updatedDate)}</span>
          </>
        )}
      </div>
      {post.data.tags.length > 0 && (
        <ul class="mt-3 flex flex-wrap gap-2 text-sm text-zinc-500 dark:text-zinc-400">
          {post.data.tags.map((t) => (
            <li>
              <a href={`/tags/${t}/`} class="hover:text-accent">#{t}</a>
            </li>
          ))}
        </ul>
      )}
    </header>

    <div class="prose prose-zinc max-w-none dark:prose-invert">
      <Content />
    </div>
    <CopyCode />

    {(newer || older) && (
      <nav class="mt-16 grid gap-4 border-t border-zinc-200 pt-8 sm:grid-cols-2 dark:border-zinc-800" aria-label="Adjacent posts">
        {newer ? (
          <a href={`/blog/${newer.slug}/`} class="group rounded-xl border border-zinc-200 p-5 transition hover:border-accent dark:border-zinc-800 dark:hover:border-accent">
            <p class="text-xs uppercase tracking-wider text-zinc-500 dark:text-zinc-400">← Newer</p>
            <p class="mt-1 font-display font-medium text-zinc-900 transition group-hover:text-accent dark:text-zinc-50">{newer.data.title}</p>
          </a>
        ) : <span />}
        {older ? (
          <a href={`/blog/${older.slug}/`} class="group rounded-xl border border-zinc-200 p-5 text-right transition hover:border-accent dark:border-zinc-800 dark:hover:border-accent">
            <p class="text-xs uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Older →</p>
            <p class="mt-1 font-display font-medium text-zinc-900 transition group-hover:text-accent dark:text-zinc-50">{older.data.title}</p>
          </a>
        ) : <span />}
      </nav>
    )}

    <p class="mt-12 text-sm">
      <a href="/blog/" class="text-accent hover:underline">← Back to blog</a>
    </p>
  </article>

  <script>
    // Client-side Mermaid: only loads the runtime on posts that contain a
    // diagram, and re-renders on light/dark toggle so it matches the theme.
    const blocks = Array.from(document.querySelectorAll<HTMLElement>('pre.mermaid'));
    if (blocks.length) {
      // Preserve the source so we can re-render from it on theme changes.
      blocks.forEach((el) => (el.dataset.src = el.textContent ?? ''));

      let rendering = false;
      const render = async () => {
        if (rendering) return;
        rendering = true;
        try {
          const { default: mermaid } = await import('mermaid');
          const dark = document.documentElement.classList.contains('dark');
          mermaid.initialize({ startOnLoad: false, theme: dark ? 'dark' : 'default' });
          blocks.forEach((el) => {
            el.removeAttribute('data-processed');
            el.innerHTML = el.dataset.src ?? '';
          });
          await mermaid.run({ nodes: blocks });
        } catch (err) {
          console.error('[mermaid] render failed', err);
          blocks.forEach((el) => (el.style.visibility = 'visible'));
        } finally {
          rendering = false;
        }
      };

      render();

      // Re-render when the theme toggle flips the `dark` class on <html>.
      let isDark = document.documentElement.classList.contains('dark');
      new MutationObserver(() => {
        const nowDark = document.documentElement.classList.contains('dark');
        if (nowDark !== isDark) {
          isDark = nowDark;
          render();
        }
      }).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    }
  </script>
</BaseLayout>
